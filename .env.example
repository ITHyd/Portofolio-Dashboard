# Copy to .env on the server and customise.

# A long random string. Generate one with: openssl rand -hex 48
JWT_SECRET=please-set-a-long-random-string

# Set a strong DB password on the server.
POSTGRES_PASSWORD=set-a-strong-password

# Comma-separated list of allowed origins for the browser.
# Defaults to http://149.102.158.71:8021 + 8024 + localhost variants.
# Override here if you put the app behind a different hostname / TLS cert.
# CORS_ORIGINS=https://portfolio.example.com

# Set to 0 after first successful deploy to skip the seed step on every restart.
RUN_SEED=1
